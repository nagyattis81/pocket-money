{
  "name": "pocket-money",
  "displayName": "Pocket Money",
  "version": "1.0.0",
  "description": "Pocket money browser extension for e-kreta",
  "author": "Nagy Attila (aha): nagy.attis.81@gmail.com",
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "package": "plasmo package",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "knip": "knip",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "plasmo": "0.90.5",
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "4.1.1",
    "@types/chrome": "0.0.258",
    "@types/node": "20.11.5",
    "@types/react": "18.2.48",
    "@types/react-dom": "18.2.18",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prefer-arrow": "^1.2.3",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "knip": "^6.0.2",
    "prettier": "3.2.4",
    "typescript": "5.3.3",
    "vitest": "^3.2.4",
    "@vitest/coverage-v8": "^3.2.4"
  },
  "overrides": {
    "content-security-policy-parser": "0.6.0",
    "esbuild": "0.27.4",
    "msgpackr": "1.11.9",
    "svelte": "5.54.1"
  },
  "manifest": {
    "permissions": [
      "scripting",
      "storage"
    ],
    "host_permissions": [
      "https://*.e-kreta.hu/TanuloErtekeles/Osztalyzatok*"
    ]
  }
}
